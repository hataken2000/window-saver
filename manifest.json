{
  "manifest_version": 3,
  "name": "Window Saver",
  "version": "1.0.0",
  "description": "ウィンドウの状態（タブグループ・ページ）を保存・復元する",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "windows"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "externally_connectable": {
    "ids": ["*"],
    "matches": [
      "https://hataken2000.github.io/*",
      "file://*/*"
    ]
  }
}
